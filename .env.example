# Copy to .env.local (gitignored) and fill in real values. Never commit real secrets.

# Optional: override the SQLite database file location.
# MYHOMEBASE_DB=./data/myhomebase.db

# "Sign in with Google" is disabled unless all three of these are set.
# Set up in Google Cloud Console -> APIs & Services -> Credentials ->
# Create Credentials -> OAuth client ID -> Application type: Web application.
# Add an "Authorized redirect URI" that matches GOOGLE_REDIRECT_URI exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match the redirect URI registered in Google Cloud Console.
# Example for local dev: http://localhost:3000/login/google/callback
GOOGLE_REDIRECT_URI=
